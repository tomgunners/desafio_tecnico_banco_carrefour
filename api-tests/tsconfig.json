{
  "compilerOptions": {
    "target":                          "ES2020",
    "module":                          "commonjs",
    "lib":                             ["ES2020"],
    "outDir":                          "./dist",
    "rootDir":                         "./src",
    "strict":                          true,
    "esModuleInterop":                 true,
    "allowSyntheticDefaultImports":    true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "baseUrl":                         ".",
    "typeRoots":                       ["node_modules/@types", "src/types"],
    "paths": {
      "@client/*":  ["src/client/*"],
      "@schemas/*": ["src/schemas/*"],
      "@utils/*":   ["src/utils/*"],
      "@config/*":  ["src/config/*"]
    }
  },
  "ts-node": {
    "transpileOnly": true,
    "esm": false,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "reports", "allure-results", "allure-report"]
}
