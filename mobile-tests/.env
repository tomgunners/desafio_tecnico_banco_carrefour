# ============================================================
# Mobile Tests — Variáveis de Ambiente
# ============================================================

# ── Appium Server ────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Android ─────────────────────────────────────────────────
# Versão do Android (deve coincidir com a tag da imagem docker-android)
ANDROID_PLATFORM_VERSION=14
# Serial do emulador — docker-android sempre expõe como emulator-5554
ANDROID_DEVICE_NAME=emulator-5554
# Nome do APK dentro da pasta apps/
ANDROID_APP_NAME=wdio-native-demo-app.apk

# ── docker-android (CI e uso local via docker compose) ───────
# Path do APK DENTRO do container (volume montado em /apps)
# Deixe comentado para execução local sem docker-android
# ANDROID_APP_CONTAINER_PATH=/apps/wdio-native-demo-app.apk

# ── iOS ──────────────────────────────────────────────────────
IOS_PLATFORM_VERSION=17.0
IOS_DEVICE_NAME=iPhone 15
IOS_APP_NAME=wdio-native-demo-app.app

# ── Timeouts ─────────────────────────────────────────────────
# Timeout global do WebdriverIO (waitForDisplayed, waitForExist, etc.)
WDIO_WAIT_TIMEOUT=15000
# Timeout implícito do Appium antes de lançar NoSuchElementError
APPIUM_IMPLICIT_WAIT=10000
# Timeout de cada comando Appium
APPIUM_COMMAND_TIMEOUT=300
# Timeouts gerais de elemento e teste
ELEMENT_TIMEOUT=15000
TEST_TIMEOUT=120000

# ── Credenciais do app ───────────────────────────────────────
STANDARD_USER=bob@example.com
STANDARD_PASSWORD=10203040
INVALID_USER=aaaaaaaaaaaaaaa
INVALID_PASSWORD=senhaerrada

# ── Ambiente ─────────────────────────────────────────────────
TEST_ENV=QA
