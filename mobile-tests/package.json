{
  "name": "mobile-tests",
  "version": "1.0.0",
  "description": "Testes Mobile com WebdriverIO v8 + Appium 2 + TypeScript — Desafio Banco Carrefour",
  "private": true,
  "scripts": {
    "test": "npm run test:android",
    "test:android": "wdio run src/config/wdio.android.conf.ts",
    "test:ios": "wdio run src/config/wdio.ios.conf.ts",
    "docker:up": "docker compose up -d && npm run docker:wait",
    "docker:wait": "node scripts/wait-for-appium.js",
    "docker:down": "docker compose down",
    "docker:test": "npm run docker:up && node scripts/docker-test.js && npm run docker:down",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "report:allure": "npm run allure:generate && npm run allure:open",
    "clean": "rimraf allure-results allure-report reports/screenshots"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@wdio/allure-reporter": "^8.36.1",
    "@wdio/appium-service": "^8.36.1",
    "@wdio/cli": "^8.36.1",
    "@wdio/globals": "^8.36.1",
    "@wdio/local-runner": "^8.36.1",
    "@wdio/mocha-framework": "^8.36.1",
    "@wdio/spec-reporter": "^8.36.1",
    "@wdio/types": "^8.36.1",
    "allure-commandline": "^2.30.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webdriverio": "^8.36.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}